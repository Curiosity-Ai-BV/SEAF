{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seaf.dev/specs/loop-run.schema.json",
  "title": "SEAF LoopRun",
  "type": "object",
  "required": [
    "run_id",
    "ticket_id",
    "goal_id",
    "provider",
    "model",
    "input_digests",
    "status",
    "current_step",
    "started_at",
    "updated_at",
    "steps",
    "policy_decisions"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "ticket_id": { "type": "string", "minLength": 1 },
    "goal_id": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "execution_mode": {
      "enum": ["legacy_proposal_only", "isolated_candidate"],
      "default": "legacy_proposal_only"
    },
    "input_digests": {
      "type": "object",
      "required": ["ticket", "policy", "config", "repository"],
      "properties": {
        "ticket": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "policy": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "config": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "repository": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "eval_config": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "status": {
      "enum": [
        "pending",
        "running",
        "awaiting_human_review",
        "approved",
        "eval_passed",
        "promoted",
        "blocked",
        "failed",
        "passed",
        "completed"
      ]
    },
    "current_step": {
      "enum": [
        "research",
        "analysis",
        "spec_creation",
        "spec_review",
        "development",
        "output_review",
        "testing",
        "eval_report"
      ]
    },
    "started_at": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {
            "enum": [
              "research",
              "analysis",
              "spec_creation",
              "spec_review",
              "development",
              "output_review",
              "testing",
              "eval_report"
            ]
          },
          "status": {
            "enum": [
              "pending",
              "running",
              "blocked",
              "failed",
              "passed",
              "completed"
            ]
          },
          "artifact_path": {
            "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
          },
          "artifact_digest": {
            "anyOf": [
              { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              { "type": "null" }
            ]
          }
        },
        "oneOf": [
          {
            "required": ["artifact_path", "artifact_digest"],
            "properties": {
              "artifact_path": { "type": "string", "minLength": 1 },
              "artifact_digest": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            }
          },
          {
            "required": ["artifact_path", "artifact_digest"],
            "properties": {
              "artifact_path": { "type": "null" },
              "artifact_digest": { "type": "null" }
            }
          },
          {
            "not": {
              "anyOf": [
                { "required": ["artifact_path"] },
                { "required": ["artifact_digest"] }
              ]
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "policy_decisions": {
      "type": "array",
      "items": { "type": "object", "minProperties": 1 }
    },
    "provider_exchange_records": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": [
          "run_id",
          "step",
          "role",
          "step_attempt",
          "exchange_index",
          "kind",
          "phase",
          "path",
          "digest"
        ],
        "properties": {
          "run_id": { "type": "string", "minLength": 1 },
          "step": {
            "enum": [
              "research",
              "analysis",
              "spec_creation",
              "spec_review",
              "development",
              "output_review"
            ]
          },
          "role": {
            "enum": [
              "researcher",
              "analyzer",
              "spec_writer",
              "spec_reviewer",
              "developer",
              "output_reviewer"
            ]
          },
          "step_attempt": { "type": "integer", "minimum": 1 },
          "exchange_index": { "type": "integer", "minimum": 1 },
          "kind": { "enum": ["initial", "json_repair", "context_retry"] },
          "context_round": { "type": "integer", "minimum": 1 },
          "phase": { "enum": ["request", "response"] },
          "path": {
            "type": "string",
            "pattern": "^artifacts/[0-9]{2}-[a-z-]+\\.attempt-[0-9]{3,}\\.exchange-[0-9]{3,}\\.(initial|json-repair|context-retry)\\.(request|response)\\.record\\.json$"
          },
          "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "allOf": [
          {
            "if": { "properties": { "kind": { "const": "initial" } } },
            "then": { "not": { "required": ["context_round"] } }
          },
          {
            "if": { "properties": { "kind": { "const": "context_retry" } } },
            "then": { "required": ["context_round"] }
          },
          {
            "if": { "properties": { "phase": { "const": "request" } } },
            "then": {
              "properties": {
                "path": { "pattern": "\\.request\\.record\\.json$" }
              }
            },
            "else": {
              "properties": {
                "path": { "pattern": "\\.response\\.record\\.json$" }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "initial" } } },
            "then": {
              "properties": {
                "path": {
                  "pattern": "\\.initial\\.(request|response)\\.record\\.json$"
                }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "json_repair" } } },
            "then": {
              "properties": {
                "path": {
                  "pattern": "\\.json-repair\\.(request|response)\\.record\\.json$"
                }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "context_retry" } } },
            "then": {
              "properties": {
                "path": {
                  "pattern": "\\.context-retry\\.(request|response)\\.record\\.json$"
                }
              }
            }
          },
          {
            "if": { "properties": { "step": { "const": "research" } } },
            "then": {
              "properties": {
                "role": { "const": "researcher" },
                "path": { "pattern": "^artifacts/01-research\\." }
              }
            }
          },
          {
            "if": { "properties": { "step": { "const": "analysis" } } },
            "then": {
              "properties": {
                "role": { "const": "analyzer" },
                "path": { "pattern": "^artifacts/02-analysis\\." }
              }
            }
          },
          {
            "if": { "properties": { "step": { "const": "spec_creation" } } },
            "then": {
              "properties": {
                "role": { "const": "spec_writer" },
                "path": { "pattern": "^artifacts/03-spec\\." }
              }
            }
          },
          {
            "if": { "properties": { "step": { "const": "spec_review" } } },
            "then": {
              "properties": {
                "role": { "const": "spec_reviewer" },
                "path": { "pattern": "^artifacts/04-spec-review\\." }
              }
            }
          },
          {
            "if": { "properties": { "step": { "const": "development" } } },
            "then": {
              "properties": {
                "role": { "const": "developer" },
                "path": { "pattern": "^artifacts/05-development\\." }
              }
            }
          },
          {
            "if": { "properties": { "step": { "const": "output_review" } } },
            "then": {
              "properties": {
                "role": { "const": "output_reviewer" },
                "path": { "pattern": "^artifacts/06-output-review\\." }
              }
            }
          }
        ],
        "additionalProperties": false
      }
    },
    "candidate_workspace": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "schema_version",
            "path",
            "source_worktree_root",
            "git_common_dir",
            "repository_identity_digest",
            "starting_head",
            "starting_tree",
            "candidate_head",
            "candidate_tree",
            "candidate_diff_digest",
            "lifecycle"
          ],
          "properties": {
            "schema_version": { "enum": [1, 2] },
            "run_directory_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "path": { "type": "string", "pattern": "^/" },
            "source_worktree_root": { "type": "string", "pattern": "^/" },
            "git_common_dir": { "type": "string", "pattern": "^/" },
            "repository_identity_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "starting_head": {
              "type": "string",
              "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
            },
            "starting_tree": {
              "type": "string",
              "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
            },
            "candidate_head": {
              "type": "string",
              "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
            },
            "candidate_tree": {
              "type": "string",
              "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
            },
            "candidate_diff_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "patch_transaction": {
              "anyOf": [
                {
                  "type": "object",
                  "required": [
                    "schema_version",
                    "phase",
                    "intent",
                    "started_at"
                  ],
                  "properties": {
                    "schema_version": { "const": 1 },
                    "phase": { "enum": ["applying", "applied"] },
                    "intent": {
                      "type": "object",
                      "required": ["path", "digest"],
                      "properties": {
                        "path": { "type": "string", "minLength": 1 },
                        "digest": {
                          "type": "string",
                          "pattern": "^[a-f0-9]{64}$"
                        }
                      },
                      "additionalProperties": false
                    },
                    "applied_evidence": {
                      "anyOf": [
                        {
                          "type": "object",
                          "required": ["path", "digest"],
                          "properties": {
                            "path": { "type": "string", "minLength": 1 },
                            "digest": {
                              "type": "string",
                              "pattern": "^[a-f0-9]{64}$"
                            }
                          },
                          "additionalProperties": false
                        },
                        { "type": "null" }
                      ]
                    },
                    "started_at": { "type": "string", "minLength": 1 },
                    "applied_at": {
                      "anyOf": [
                        { "type": "string", "minLength": 1 },
                        { "type": "null" }
                      ]
                    }
                  },
                  "allOf": [
                    {
                      "if": {
                        "required": ["phase"],
                        "properties": { "phase": { "const": "applying" } }
                      },
                      "then": {
                        "properties": {
                          "applied_evidence": { "type": "null" },
                          "applied_at": { "type": "null" }
                        }
                      }
                    },
                    {
                      "if": {
                        "required": ["phase"],
                        "properties": { "phase": { "const": "applied" } }
                      },
                      "then": {
                        "required": ["applied_evidence", "applied_at"],
                        "properties": {
                          "applied_evidence": { "type": "object" },
                          "applied_at": { "type": "string", "minLength": 1 }
                        }
                      }
                    }
                  ],
                  "additionalProperties": false
                },
                { "type": "null" }
              ]
            },
            "lifecycle": {
              "enum": ["provisioning", "active", "cleaning", "cleaned"]
            },
            "cleanup_started_at": {
              "anyOf": [
                { "type": "string", "minLength": 1 },
                { "type": "null" }
              ]
            },
            "cleaned_at": {
              "anyOf": [
                { "type": "string", "minLength": 1 },
                { "type": "null" }
              ]
            }
          },
          "allOf": [
            {
              "if": {
                "properties": { "schema_version": { "const": 1 } }
              },
              "then": {
                "not": { "required": ["run_directory_digest"] }
              }
            },
            {
              "if": {
                "properties": { "schema_version": { "const": 2 } }
              },
              "then": { "required": ["run_directory_digest"] }
            },
            {
              "if": {
                "required": ["lifecycle"],
                "properties": { "lifecycle": { "const": "provisioning" } }
              },
              "then": {
                "properties": {
                  "patch_transaction": { "type": "null" },
                  "cleanup_started_at": { "type": "null" },
                  "cleaned_at": { "type": "null" }
                }
              }
            },
            {
              "if": {
                "required": ["patch_transaction"],
                "properties": {
                  "patch_transaction": {
                    "type": "object",
                    "required": ["phase"],
                    "properties": { "phase": { "const": "applied" } }
                  }
                }
              },
              "then": {
                "properties": {
                  "candidate_diff_digest": {
                    "not": {
                      "const": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
                    }
                  }
                }
              },
              "else": {
                "properties": {
                  "candidate_diff_digest": {
                    "const": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855"
                  }
                }
              }
            },
            {
              "if": { "properties": { "lifecycle": { "const": "active" } } },
              "then": {
                "properties": {
                  "cleanup_started_at": { "type": "null" },
                  "cleaned_at": { "type": "null" }
                }
              }
            },
            {
              "if": { "properties": { "lifecycle": { "const": "cleaning" } } },
              "then": {
                "required": ["cleanup_started_at"],
                "properties": {
                  "cleanup_started_at": { "type": "string", "minLength": 1 },
                  "cleaned_at": { "type": "null" }
                }
              }
            },
            {
              "if": { "properties": { "lifecycle": { "const": "cleaned" } } },
              "then": {
                "required": ["cleanup_started_at", "cleaned_at"],
                "properties": {
                  "cleanup_started_at": { "type": "string", "minLength": 1 },
                  "cleaned_at": { "type": "string", "minLength": 1 }
                }
              }
            }
          ],
          "additionalProperties": false
        },
        { "type": "null" }
      ]
    },
    "human_approval": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "schema_version",
            "run_id",
            "reviewer",
            "approved_at",
            "candidate_diff",
            "starting_head",
            "policy_decision_digest",
            "output_review",
            "output_review_request",
            "output_review_response"
          ],
          "properties": {
            "schema_version": { "const": 1 },
            "run_id": { "type": "string", "minLength": 1 },
            "reviewer": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[^\\x00-\\x1f\\x7f]*$"
            },
            "approved_at": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "candidate_diff": {
              "type": "object",
              "required": ["path", "digest"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              },
              "additionalProperties": false
            },
            "starting_head": {
              "type": "string",
              "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
            },
            "policy_decision_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "output_review": {
              "type": "object",
              "required": ["path", "digest"],
              "properties": {
                "path": { "type": "string", "minLength": 1 },
                "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              },
              "additionalProperties": false
            },
            "output_review_request": {
              "type": "object",
              "required": [
                "run_id",
                "step",
                "role",
                "step_attempt",
                "exchange_index",
                "kind",
                "phase",
                "path",
                "digest"
              ],
              "properties": {
                "run_id": { "type": "string", "minLength": 1 },
                "step": { "const": "output_review" },
                "role": { "const": "output_reviewer" },
                "step_attempt": { "type": "integer", "minimum": 1 },
                "exchange_index": { "const": 1 },
                "kind": { "const": "initial" },
                "phase": { "const": "request" },
                "path": {
                  "type": "string",
                  "pattern": "^artifacts/06-output-review\\.attempt-[0-9]{3,}\\.exchange-001\\.initial\\.request\\.record\\.json$"
                },
                "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              },
              "additionalProperties": false
            },
            "output_review_response": {
              "type": "object",
              "required": [
                "run_id",
                "step",
                "role",
                "step_attempt",
                "exchange_index",
                "kind",
                "phase",
                "path",
                "digest"
              ],
              "properties": {
                "run_id": { "type": "string", "minLength": 1 },
                "step": { "const": "output_review" },
                "role": { "const": "output_reviewer" },
                "step_attempt": { "type": "integer", "minimum": 1 },
                "exchange_index": { "type": "integer", "minimum": 1 },
                "kind": { "enum": ["initial", "json_repair", "context_retry"] },
                "context_round": { "type": "integer", "minimum": 1 },
                "phase": { "const": "response" },
                "path": {
                  "type": "string",
                  "pattern": "^artifacts/06-output-review\\.attempt-[0-9]{3,}\\.exchange-[0-9]{3,}\\.(initial|json-repair|context-retry)\\.response\\.record\\.json$"
                },
                "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        { "type": "null" }
      ]
    },
    "eval_report_path": {
      "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
    },
    "promotion": {
      "anyOf": [
        {
          "type": "object",
          "required": [
            "schema_version",
            "run_id",
            "reviewer",
            "promoted_at",
            "intent",
            "candidate_diff",
            "testing_evidence",
            "eval_report",
            "policy_decision_digest",
            "target_head",
            "eval_passed_run_digest",
            "eval_passed_updated_at"
          ],
          "properties": {
            "schema_version": { "const": 1 },
            "run_id": { "type": "string", "minLength": 1 },
            "reviewer": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "pattern": "^[^\\x00-\\x1f\\x7f]*$"
            },
            "promoted_at": { "type": "string", "pattern": "^(0|[1-9][0-9]*)$" },
            "intent": { "$ref": "#/$defs/artifactReference" },
            "candidate_diff": { "$ref": "#/$defs/artifactReference" },
            "testing_evidence": { "$ref": "#/$defs/artifactReference" },
            "eval_report": { "$ref": "#/$defs/artifactReference" },
            "policy_decision_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "target_head": {
              "type": "string",
              "pattern": "^(?:[a-f0-9]{40}|[a-f0-9]{64})$"
            },
            "eval_passed_run_digest": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "eval_passed_updated_at": {
              "type": "string",
              "pattern": "^(0|[1-9][0-9]*)$"
            }
          },
          "additionalProperties": false
        },
        { "type": "null" }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": ["status"],
        "properties": { "status": { "const": "awaiting_human_review" } }
      },
      "then": {
        "required": [
          "execution_mode",
          "provider_exchange_records",
          "candidate_workspace"
        ],
        "properties": {
          "execution_mode": { "const": "isolated_candidate" },
          "current_step": { "const": "testing" },
          "candidate_workspace": {
            "type": "object",
            "required": ["schema_version", "lifecycle", "patch_transaction"],
            "properties": {
              "schema_version": { "const": 2 },
              "lifecycle": { "const": "active" },
              "patch_transaction": {
                "type": "object",
                "required": ["phase"],
                "properties": { "phase": { "const": "applied" } }
              }
            }
          },
          "provider_exchange_records": {
            "minItems": 2,
            "allOf": [
              {
                "contains": {
                  "required": ["step", "role", "kind", "phase"],
                  "properties": {
                    "step": { "const": "output_review" },
                    "role": { "const": "output_reviewer" },
                    "kind": { "const": "initial" },
                    "phase": { "const": "request" }
                  }
                },
                "minContains": 1
              },
              {
                "contains": {
                  "required": ["step", "role", "phase"],
                  "properties": {
                    "step": { "const": "output_review" },
                    "role": { "const": "output_reviewer" },
                    "phase": { "const": "response" }
                  }
                },
                "minContains": 1
              }
            ]
          },
          "steps": {
            "allOf": [
              {
                "contains": {
                  "required": ["name"],
                  "properties": { "name": { "const": "development" } }
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "required": ["name"],
                  "properties": { "name": { "const": "output_review" } }
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "required": ["name"],
                  "properties": { "name": { "const": "testing" } }
                },
                "minContains": 1,
                "maxContains": 1
              },
              {
                "contains": {
                  "required": ["name"],
                  "properties": { "name": { "const": "eval_report" } }
                },
                "minContains": 1,
                "maxContains": 1
              }
            ],
            "items": {
              "allOf": [
                {
                  "if": {
                    "required": ["name"],
                    "properties": { "name": { "const": "development" } }
                  },
                  "then": {
                    "properties": { "status": { "const": "completed" } }
                  }
                },
                {
                  "if": {
                    "required": ["name"],
                    "properties": { "name": { "const": "output_review" } }
                  },
                  "then": {
                    "required": ["artifact_path", "artifact_digest"],
                    "properties": {
                      "status": { "const": "passed" },
                      "artifact_path": { "type": "string", "minLength": 1 },
                      "artifact_digest": {
                        "type": "string",
