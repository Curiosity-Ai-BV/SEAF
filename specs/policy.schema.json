{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seaf.dev/specs/policy.schema.json",
  "title": "SEAF Policy",
  "type": "object",
  "required": [
    "policy_id",
    "default_autonomy_level",
    "forbidden_paths",
    "requires_human_review",
    "allowed_without_review"
  ],
  "properties": {
    "policy_id": { "type": "string", "minLength": 1 },
    "default_autonomy_level": { "type": "integer", "minimum": 0, "maximum": 4 },
    "forbidden_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "requires_human_review": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "allowed_without_review": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "additionalProperties": false
}
